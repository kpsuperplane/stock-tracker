{
  "name": "stock-movement-explainer",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "astryx": {
    "theme": "neutral"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "astryx": "node node_modules/@astryxdesign/cli/bin/astryx.mjs",
    "types:worker": "wrangler types",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run --config vitest.config.ts",
    "test:worker": "vitest run --config vitest.worker.config.ts",
    "check": "npm run types:worker && npm run lint && npm run typecheck && npm run test && npm run test:worker && npm run build",
    "deploy:production": "npm run check && wrangler d1 migrations apply DB --remote && wrangler deploy"
  },
  "dependencies": {
    "@astryxdesign/core": "0.1.4",
    "@astryxdesign/theme-neutral": "0.1.4",
    "@stylexjs/stylex": "0.18.3",
    "decimal.js": "^10.6.0",
    "fast-xml-parser": "5.9.3",
    "hono": "4.12.28",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-is": "19.2.7",
    "recharts": "3.8.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@astryxdesign/cli": "0.1.4",
    "@biomejs/biome": "2.5.3",
    "@cloudflare/vite-plugin": "1.44.0",
    "@cloudflare/vitest-pool-workers": "0.18.4",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "wrangler": "4.110.0"
  }
}
